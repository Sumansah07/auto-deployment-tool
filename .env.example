# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Required scopes: repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Render API Key
# Get from: https://dashboard.render.com/ → Account Settings → API Keys
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx

# Render Owner ID
# Get by running: curl -H "Authorization: Bearer YOUR_RENDER_API_KEY" https://api.render.com/v1/owners
RENDER_OWNER_ID=own-xxxxxxxxxxxxxxxxxxxx

# Server Port (optional, defaults to 3000)
PORT=3000

# Optional: API key for authentication
# DEPLOYMENT_API_KEY=your-secret-key-here
